{
  "name": "hermes-battlestation",
  "version": "0.1.0",
  "private": true,
  "description": "An alternative Hermes launcher \u2014 desktop + mobile cockpit for your local agent: chat, repos, fleet, kanban, terminal, editor.",
  "author": "Hermes Battlestation",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=30",
    "typecheck": "tsc --noEmit",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:build": "next build && cap copy",
    "electron:dev": "next build && electron .",
    "electron:rebuild": "electron-rebuild -f -w node-pty",
    "dist": "rm -rf release && next build && node scripts/prepare-standalone.cjs && electron-builder",
    "dist:linux": "rm -rf release && next build && node scripts/prepare-standalone.cjs && electron-builder --linux",
    "dist:mac": "rm -rf release && next build && node scripts/prepare-standalone.cjs && electron-builder --mac",
    "dist:win": "rm -rf release && next build && node scripts/prepare-standalone.cjs && electron-builder --win"
  },
  "dependencies": {
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.40.0",
    "next": "16.2.7",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "4.11.2",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.19.41",
    "@types/react": "19.2.16",
    "@types/react-dom": "^19",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.example.battlestation",
    "productName": "Hermes Battlestation",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "!**/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node-pty/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Nous Research <hello@nousresearch.com>",
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "npmRebuild": false
  }
}
