# DEMI Workspace — server-side config. Never expose these to the client.
# Copy to .env.local and fill in. With nothing set, the app runs entirely
# against localhost and leaks no infrastructure.

# ── Hermes dashboard (loopback) ──────────────────────────────────────────────
# Used server-side to scrape the per-process session token and proxy
# /api/cron/jobs. The browser never sees the token.
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Embedded chat target for the center pane iframe. Browse from the host (the
# dashboard binds loopback and rejects non-loopback Host headers).
NEXT_PUBLIC_HERMES_CHAT_URL=http://127.0.0.1:9119/chat

# Path to the `hermes` binary used to spawn the ACP chat bridge.
HERMES_BIN=hermes

# Model provider label shown in the picker. Public Anthropic model IDs are fine.
NEXT_PUBLIC_MODEL_PROVIDER=anthropic

# ── Content sources ──────────────────────────────────────────────────────────
# Obsidian vault root for the decisions/inbox panes. Defaults to
# "$HOME/Obsidian Vault" when unset.
OBSIDIAN_VAULT_PATH=

# GitHub org/user for the Repos pane (`gh repo list <org>`). Empty = your repos.
GH_ORG=

# ── Fleet nodes (all optional) ───────────────────────────────────────────────
# Per node MATCH = tailnet peer name for online/last-seen status; SSH = ssh
# prefix to run a remote command ("" = local); GPU/SYS = ssh alias for a
# read-only nvidia-smi / cpu-ram probe ("self" = local); AGENT = URL of the
# box's hermes agent/dashboard health endpoint (the fleet's "agents only"
# access — an HTTP GET, never a shell). Unset nodes are skipped.
# PC1 defaults to local probing; the rest are off until configured.
FLEET_PC1_MATCH=localhost
FLEET_PC1_SSH=
FLEET_PC1_GPU=self
FLEET_PC1_SYS=self
FLEET_PC1_AGENT=http://127.0.0.1:9119

FLEET_PC2_MATCH=
FLEET_PC2_SSH=
FLEET_PC2_GPU=
FLEET_PC2_SYS=
FLEET_PC2_AGENT=

FLEET_MAC_MATCH=
FLEET_MAC_SSH=
FLEET_MAC_SYS=
FLEET_MAC_AGENT=

FLEET_VPS_MATCH=
FLEET_VPS_SSH=
FLEET_VPS_SYS=
FLEET_VPS_AGENT=
# pm2 process-name family treated as bot-health on the VPS (regex).
FLEET_VPS_PROC=^app-(server|worker)

# ── Polymarket bot panel ─────────────────────────────────────────────────────
# SSH alias for the bot host and the pm2 process name to read.
POLY_HOST=
POLY_PROC=app-server

# ── Web push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:you@example.com

# ── Capacitor (iOS shell) ────────────────────────────────────────────────────
# Remote URL the native app loads. Defaults to http://localhost:9119.
CAP_SERVER_URL=
